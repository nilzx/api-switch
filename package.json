{
  "name": "api-switch",
  "version": "0.1.1",
  "description": "Switch 3rd-party API settings for 'Claude Code' and 'Codex CLI'.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "api-switch": "dist/bin/api-switch.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
